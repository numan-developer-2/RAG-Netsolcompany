# Required for Gemini LLM and embedding calls.
GOOGLE_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional LangSmith tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=netsol-rag

# Optional overrides.
EMBED_MODEL=gemini-embedding-2-preview
EMBEDDING_PROVIDER=local
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gemini-2.0-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
LLM_PROVIDER=openrouter
USE_CROSS_ENCODER=false

# RAG answer brevity and context controls.
SIMPLE_CONTEXT_CHUNKS=3
COMPLEX_CONTEXT_CHUNKS=5
CONTEXT_CHARS_PER_CHUNK=900
ANSWER_MAX_WORDS=90
GENERATION_MAX_TOKENS=384

API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
